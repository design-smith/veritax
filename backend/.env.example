# Postgres (you provide this; pgvector must be available)
DATABASE_URL=postgresql+asyncpg://veritax:veritax@localhost:5432/veritax

# Object storage (MinIO / S3-compatible)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=veritax-sources
S3_REGION=us-east-1

# Embeddings (Voyage)
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-law-2
EMBEDDING_DIM=1024

# Requirement-coverage assessment + drafting (Anthropic)
ANTHROPIC_API_KEY=
ASSESSMENT_MODEL=claude-haiku-4-5
DRAFT_MODEL=claude-sonnet-4-6

# DeepSeek (OpenAI-compatible). If set, used for assessment + drafting instead of Anthropic.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# CORS (frontend dev origin)
CORS_ORIGINS=http://localhost:3000
